# LLM chat endpoint.
# Leave LLM_API_KEY empty to use deterministic demo mode for answer generation.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedding endpoint.
# Leave EMBEDDING_API_KEY empty to use local HashEmbeddings for offline demos.
EMBEDDING_PROVIDER=ollama
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# Backward-compatible fallback.
# If LLM_* or EMBEDDING_* is not set, the app falls back to OPENAI_*.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional overrides
PHARMASSIST_CONFIG=config/config.yaml
